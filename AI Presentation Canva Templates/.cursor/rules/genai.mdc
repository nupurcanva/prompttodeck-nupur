## 🔑 Quick Reference

```typescript
// AIService - Unified interface (recommended)
import { AIService } from "@canva-ct/genai";
const ai = new AIService();
await ai.chat({ messages, model });
await ai.generateImage({ prompt });

// fal.ai - 600+ media models
import { fal } from "@canva-ct/genai/fal";
await fal.subscribe("fal-ai/nano-banana-pro", { input: { prompt } });

// OpenRouter - Direct API
import { OpenRouterService } from "@canva-ct/genai/openrouter";
const openrouter = new OpenRouterService();
await openrouter.chat({ messages, model });

// TTS - Text-to-Speech
import { TTSService } from "@canva-ct/genai/tts";
const tts = new TTSService();
await tts.speak({ input: "Hello", model: "tts-1", voice: "coral" });
```

